{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "onboarding-bot",
  "compatibility_date": "2026-06-11",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "observability": {
    "enabled": true
  },
  "vars": {
    "WEB_APP_URL": "https://onboarding-bot.telecraft.workers.dev/verify"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "onboarding-bot",
      "database_id": "b1f86df0-47cd-42c7-9002-22af58873993"
    }
  ]
}
